# Database Configuration (PostgreSQL already installed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kitchen_db
DB_USER=kitchen_user
DB_PASSWORD=your_secure_password_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-random-secret-key-in-production

# JWT Configuration
JWT_SECRET_KEY=change-this-to-random-jwt-secret-in-production
JWT_EXPIRATION_HOURS=24

# Server Configuration (bind to 0.0.0.0 for Wi-Fi access)
HOST=0.0.0.0
PORT=5000

# Business Configuration
TAX_RATE=0.00

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
